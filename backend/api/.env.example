# ─────────────────────────────────────────────
# Enterprise Command Center — API Environment
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecc_db

# Or use individual fields:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ecc_db
# DB_USER=postgres
# DB_PASSWORD=password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS — dev: http://localhost:5173 | prod: https://ecc-api.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MCP server URL — dev: http://localhost:3002 | prod: https://ecc-mcp.onrender.com
MCP_SERVER_URL=http://localhost:3002

# AI Keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# Platform credentials (optional — only needed if using MCP browser automation locally)
# SV_EMAIL=admin@yourplatform.com
# SV_PASSWORD=your-password
