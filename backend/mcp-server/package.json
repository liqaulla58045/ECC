{
    "name": "startupvarsity-admin-mcp",
    "version": "2.0.0",
    "description": "MCP server for StartupVarsity admin dashboard — exposes live data via Playwright browser automation",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc && npx playwright install chromium --with-deps",
        "start": "node dist/server.js",
        "dev": "npx tsx server.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "playwright": "^1.40.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^20.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.0.0"
    }
}
